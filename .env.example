# =============================================================================
# Dental AI Agent - Environment Variables
# Copy this file to .env and fill in your keys
# =============================================================================

# OpenAI (Required)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o                   # Use gpt-4o-mini for cost savings during dev

# Pinecone (Required for RAG)
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=dental-agent
PINECONE_ENVIRONMENT=us-east-1        # Or your region

# LangSmith (Required for observability)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=dental-agent-dev
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Twilio (Optional - only needed for SMS channel)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# PostgreSQL (Optional - for persistent conversation state)
# If not set, uses in-memory checkpointer (fine for dev)
DATABASE_URL=postgresql://user:pass@localhost:5432/dental_agent

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
